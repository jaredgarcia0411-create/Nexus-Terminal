# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostgreSQL via Neon (optional — app falls back to localStorage if not set)
# Format: postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/nexus_terminal?sslmode=require
DATABASE_URL=

# Jarvis assistant (optional — enables LLM responses)
JARVIS_API_KEY=
JARVIS_API_BASE_URL=https://integrate.api.nvidia.com/v1
JARVIS_MODEL=deepseek-v3.2
JARVIS_MAX_CONTEXT_TOKENS=6000
JARVIS_USER_STORAGE_LIMIT_BYTES=104857600
JARVIS_ADMIN_KEY=
JARVIS_EMBEDDING_ENABLED=true
JARVIS_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
JARVIS_EMBEDDING_API_BASE_URL=https://integrate.api.nvidia.com/v1/embeddings

# AI Providers
NVIDIA_API_KEY=

# Access Control (optional — comma-separated emails, empty = allow all)
ALLOWED_EMAILS=
