# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostgreSQL via Neon (optional — app falls back to localStorage if not set)
# Format: postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/nexus_terminal?sslmode=require
DATABASE_URL=

# Schwab API (optional — for backtesting data)
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=

# Access Control (optional — comma-separated emails, empty = allow all)
ALLOWED_EMAILS=

# Service-to-service auth (required for Discord bot and webhook integrations)
TRADE_WEBHOOK_SECRET=
TRADE_WEBHOOK_SECRET_PREVIOUS=

# Discord integrations
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
NEXUS_API_BASE_URL=

# Service and cron orchestration
BACKTEST_GATEWAY_URL=http://localhost:4000
CRON_SECRET=
